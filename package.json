{
  "name": "d-viva-assistant-agent",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm test",
    "electron:pack": "node scripts/pack-electron.mjs",
    "electron:pack:mac:arm64": "node scripts/pack-electron.mjs --arch arm64",
    "electron:pack:mac:x64": "node scripts/pack-electron.mjs --arch x64",
    "electron:pack:mac:universal": "node scripts/pack-electron.mjs --arch universal"
  },
  "build": {
    "appId": "com.handong66.dvivaassistantagent",
    "productName": "D-viva-assistant-agent",
    "files": [
      "electron/**",
      "package.json",
      "!node_modules/**"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      }
    ],
    "mac": {
      "target": "dir",
      "identity": null
    },
    "directories": {
      "output": "dist-electron"
    }
  },
  "dependencies": {
    "ai": "^7.0.2",
    "better-sqlite3": "^12.11.1",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.5",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
