# LLM - the app works locally with AI disabled. To enable AI, set
# VIVA_AI_ENABLED=true, all VIVA_MODEL_* values, and AI_GATEWAY_API_KEY.
# Additional provider credentials below are optional and transport-dependent.
# Tests always mock.
VIVA_AI_ENABLED=false
VIVA_MODEL_DEFAULT=
VIVA_MODEL_HARD=
VIVA_MODEL_FAST=
AI_GATEWAY_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Vertex needs ADC credentials (not just a project id) to count as enabled.
GOOGLE_VERTEX_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
# STT (default off; google_cloud is explicit opt-in)
STT_PROVIDER=off
GOOGLE_STT_API_KEY=
# Absolute dir for stored audio; defaults to ./recordings under the app CWD.
RECORDINGS_DIR=
# Set RUN_LIVE_AI=1 only for explicit live-provider smoke tests.
RUN_LIVE_AI=
# Tests / DB
VIVA_DB_PATH=./data/d-viva-assistant-agent.sqlite
